# Apptainer definition file for this environment.
#
# Build:  apptainer build container.sif container.def
#
# The container packages everything a scientist agent needs to work on
# this paper's task. The agent's workspace is bind-mounted at /home/user
# at runtime — it is NOT baked into the container.
#
# *** IMPORTANT ***
# Python packages (torch, transformers, etc.) go in setup.sh, NOT here.
# Only OS-level packages belong in %post.

Bootstrap: docker
From: mcr.microsoft.com/aifx/acpt/stable-ubuntu2204-cu124-py310-torch250:biweekly.202412.1

%post
    # Create workspace directory
    mkdir -p /home/user/data
    chmod 755 /home/user
    # Activate conda environment with PyTorch
    echo 'source /opt/conda/etc/profile.d/conda.sh' >> /etc/bash.bashrc
    echo 'conda activate ptca' >> /etc/bash.bashrc
    echo 'export HOME=/home/user' >> /etc/bash.bashrc

%environment
    export HOME=/home/user
    export PYTHONUNBUFFERED=1
    export PATH=/opt/conda/envs/ptca/bin:$PATH
    export CUDA_HOME=/usr/local/cuda
    export LD_LIBRARY_PATH=/opt/conda/envs/ptca/lib:$LD_LIBRARY_PATH
