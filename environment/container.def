# Apptainer definition file for this environment.
#
# Build:  apptainer build container.sif container.def
#
# The container packages everything a scientist agent needs to work on
# this paper's task. The agent's workspace is bind-mounted at /home/user
# at runtime — it is NOT baked into the container.
#
# *** IMPORTANT ***
# Python packages (torch, transformers, etc.) go in setup.sh, NOT here.
# Only OS-level packages (tdnf) belong in %post.
# Putting pip install in %post is the #1 cause of build failures.

# --- Base image: Azure Linux with Python 3.12 from MCR ---
# Azure Linux is freely available on MCR without authentication.
# Python 3.12 pre-installed. Uses tdnf (not apt) for package management.
# MCR manifest verified accessible (HTTP 200, schema v2).
Bootstrap: docker
From: mcr.microsoft.com/azurelinux/base/python:3.12

%post
    # Azure Linux uses tdnf as its package manager (not apt-get)
    # Python 3.12 is pre-installed. Install additional tools.
    tdnf install -y \
        git \
        vim \
        ca-certificates \
        curl \
        && mkdir -p /home/user/data \
        && chmod 755 /home/user

%environment
    export HOME=/home/user
    export PYTHONUNBUFFERED=1
