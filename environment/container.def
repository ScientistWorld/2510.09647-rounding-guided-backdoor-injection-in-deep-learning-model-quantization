# Apptainer definition file for this environment.
#
# Build:  apptainer build container.sif container.def
#
# The container packages everything a scientist agent needs to work on
# this paper's task. The agent's workspace is bind-mounted at /home/user
# at runtime — it is NOT baked into the container.
#
# *** IMPORTANT ***
# Python packages (torch, transformers, etc.) go in setup.sh, NOT here.
# Only OS-level packages (apt-get) belong in %post.
# Putting pip install in %post is the #1 cause of build failures.

# --- Base image: Azure Linux Python from pre-extracted rootfs on GPFS ---
# The rootfs was extracted from MCR blobs downloaded during this agent turn.
# Using localimage bootstrap avoids any registry access during build.
# Rootfs at /tmp/claude-code-tmp/rootfs (GPFS, in APPTAINER_BIND, 138MB).
# This path is accessible from both the agent session and the build host.
Bootstrap: localimage
From: /tmp/claude-code-tmp/rootfs

%post
    tdnf install -y \
        libomp \
        openssl \
        curl \
        wget \
        git \
        vim \
        ca-certificates \
        && mkdir -p /home/user/data \
        && chmod 755 /home/user

%environment
    export HOME=/home/user
    export PYTHONUNBUFFERED=1
